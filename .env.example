# Upstream API configuration
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-your-api-key-here
UPSTREAM_PROVIDER=openai

# Redis for conversation state persistence (Docker Compose built-in)
REDIS_URL=redis://redis:6379/0

# Server settings
HOST=0.0.0.0
PORT=33131

# Timeouts (seconds)
UPSTREAM_TIMEOUT_CONNECT=10
UPSTREAM_TIMEOUT_READ=300

# Conversation store
MAX_CONVERSATION_HISTORY=100
CONVERSATION_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_UPSTREAM_REQUESTS=false
LOG_UPSTREAM_RESPONSES=false

# Optional: write JSON debug logs to file (leave empty to disable)
# DEBUG_LOG_FILE=./debug.log